---
const photos = [
  { src: "/photos/band-03.jpg", alt: "Band posing together outdoors in the sun" },
  { src: "/photos/rocking-03.jpg", alt: "Guitarist playing under red and blue stage lights" },
  { src: "/photos/band-06.jpg", alt: "Band standing on a hilltop in golden hour light" },
  { src: "/photos/rocking-05.jpg", alt: "Bassist performing on stage with sunkissed banner" },
  { src: "/photos/band-09.jpg", alt: "Band hanging out in a San Francisco park" },
  { src: "/photos/rocking-01.jpg", alt: "Drummer smiling behind the kit under pink light" },
  { src: "/photos/band-04.jpg", alt: "Band posing together at a venue" },
  { src: "/photos/rocking-06.jpg", alt: "Band member looking up under stage lights" },
  { src: "/photos/band-07.jpg", alt: "Band members hanging out in a parking lot at sunset" },
  { src: "/photos/rocking-04.jpg", alt: "Bassist playing in front of psychedelic sun backdrop" },
  { src: "/photos/band-02.jpg", alt: "Band on stage together after a show" },
  { src: "/photos/rocking-10.jpg", alt: "Full band rocking out on stage" },
  { src: "/photos/band-05.jpg", alt: "Band posing under marquee sign at venue" },
  { src: "/photos/rocking-07.jpg", alt: "Guitarist shredding on stage in black and white" },
  { src: "/photos/band-08.jpg", alt: "Band portrait on a dry hillside under blue sky" },
  { src: "/photos/rocking-09.jpg", alt: "Saxophonist playing under red stage lighting" },
  { src: "/photos/band-01.jpg", alt: "Band members smiling together outside at night" },
  { src: "/photos/rocking-08.jpg", alt: "Bassist performing with sunkissed banner behind" },
  { src: "/photos/rocking-02.jpg", alt: "Drummer playing with in-ear monitors" },
];
---

<section id="photos" class="photo-carousel-section">
  <div class="carousel-track" id="carousel-track">
    {photos.map((photo, index) => (
      <button
        class="carousel-item"
        data-index={index}
        type="button"
        aria-label={`View photo: ${photo.alt}`}
      >
        <img
          src={photo.src}
          alt={photo.alt}
          loading={index < 4 ? "eager" : "lazy"}
          decoding="async"
        />
      </button>
    ))}
  </div>

  <div class="lightbox" id="photo-lightbox" role="dialog" aria-modal="true" aria-label="Photo viewer" hidden tabindex="-1">
    <div class="lightbox-backdrop"></div>
    <button class="lightbox-close" aria-label="Close photo viewer">&times;</button>
    <button class="lightbox-prev" aria-label="Previous photo">&#8249;</button>
    <button class="lightbox-next" aria-label="Next photo">&#8250;</button>
    <div class="lightbox-img-container">
      <img class="lightbox-img" src="" alt="" />
    </div>
    <div class="lightbox-counter"></div>
  </div>
</section>

<style>
  .photo-carousel-section {
    background: var(--burnt-umber);
    padding: 0;
    overflow: hidden;
    border-top: 6px solid var(--acid-yellow);
    border-bottom: 6px solid var(--acid-yellow);
  }

  .carousel-track {
    display: flex;
    gap: 4px;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
    cursor: grab;
    will-change: transform;
  }

  .carousel-track::-webkit-scrollbar {
    display: none;
  }

  .carousel-track:active {
    cursor: grabbing;
  }

  .carousel-item {
    flex: 0 0 auto;
    scroll-snap-align: start;
    height: 600px;
    border: none;
    padding: 0;
    margin: 0;
    background: none;
    cursor: pointer;
    display: block;
    line-height: 0;
    outline-offset: -3px;
  }

  .carousel-item:focus-visible {
    outline: 3px solid var(--acid-yellow);
  }

  .carousel-item img {
    height: 100%;
    width: auto;
    display: block;
    object-fit: cover;
    filter: sepia(10%) contrast(105%);
    transition: filter 0.3s ease;
  }

  .carousel-item:hover img,
  .carousel-item:focus-visible img {
    filter: sepia(0%) contrast(110%) brightness(105%);
  }

  /* Lightbox */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 10002;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox[hidden] {
    display: none;
  }

  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(61, 12, 2, 0.95);
  }

  .lightbox-img-container {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox-img {
    max-width: 90vw;
    max-height: 85vh;
    object-fit: contain;
    display: block;
    filter: none;
  }

  .lightbox-close {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    z-index: 2;
    background: none;
    border: none;
    color: var(--cream-paper);
    font-size: 3rem;
    cursor: pointer;
    line-height: 1;
    padding: 0.5rem;
    transition: color 0.2s ease;
  }

  .lightbox-close:hover,
  .lightbox-close:focus-visible {
    color: var(--acid-yellow);
  }

  .lightbox-prev,
  .lightbox-next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    background: none;
    border: none;
    color: var(--cream-paper);
    font-size: 4rem;
    cursor: pointer;
    padding: 1rem;
    transition: color 0.2s ease;
    user-select: none;
    line-height: 1;
  }

  .lightbox-prev { left: 1rem; }
  .lightbox-next { right: 1rem; }

  .lightbox-prev:hover,
  .lightbox-prev:focus-visible,
  .lightbox-next:hover,
  .lightbox-next:focus-visible {
    color: var(--acid-yellow);
  }

  .lightbox-counter {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    font-family: 'Anton', sans-serif;
    font-size: 1rem;
    letter-spacing: 3px;
    color: var(--cream-paper);
    opacity: 0.7;
  }

  @media (max-width: 1024px) {
    .carousel-item {
      height: 480px;
    }
  }

  @media (max-width: 768px) {
    .carousel-item {
      height: 350px;
      scroll-snap-align: center;
    }

    .lightbox-prev,
    .lightbox-next {
      font-size: 2.5rem;
      padding: 0.5rem;
    }

    .lightbox-prev { left: 0.5rem; }
    .lightbox-next { right: 0.5rem; }

    .lightbox-close {
      top: 1rem;
      right: 1rem;
      font-size: 2.5rem;
    }
  }

  @media (max-width: 480px) {
    .carousel-item {
      height: 280px;
    }
  }
</style>

<script>
  (function() {
    const lightbox = document.getElementById('photo-lightbox');
    const lightboxImg = lightbox.querySelector('.lightbox-img');
    const lightboxCounter = lightbox.querySelector('.lightbox-counter');
    const items = document.querySelectorAll('.carousel-item');
    const photos = Array.from(items).map(item => ({
      src: item.querySelector('img').src,
      alt: item.querySelector('img').alt
    }));
    let currentIndex = 0;
    let touchStartX = 0;

    function openLightbox(index) {
      currentIndex = index;
      updateLightboxImage();
      lightbox.hidden = false;
      document.body.style.overflow = 'hidden';
      lightbox.focus();
    }

    function closeLightbox() {
      lightbox.hidden = true;
      document.body.style.overflow = '';
      items[currentIndex]?.focus();
    }

    function updateLightboxImage() {
      lightboxImg.src = photos[currentIndex].src;
      lightboxImg.alt = photos[currentIndex].alt;
      lightboxCounter.textContent = (currentIndex + 1) + ' / ' + photos.length;
    }

    function navigate(direction) {
      currentIndex = (currentIndex + direction + photos.length) % photos.length;
      updateLightboxImage();
    }

    items.forEach(function(item, index) {
      item.addEventListener('click', function() { openLightbox(index); });
    });

    lightbox.querySelector('.lightbox-close').addEventListener('click', closeLightbox);
    lightbox.querySelector('.lightbox-backdrop').addEventListener('click', closeLightbox);
    lightbox.querySelector('.lightbox-prev').addEventListener('click', function() { navigate(-1); });
    lightbox.querySelector('.lightbox-next').addEventListener('click', function() { navigate(1); });

    document.addEventListener('keydown', function(e) {
      if (lightbox.hidden) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') navigate(-1);
      if (e.key === 'ArrowRight') navigate(1);
    });

    lightbox.addEventListener('touchstart', function(e) {
      touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });

    lightbox.addEventListener('touchend', function(e) {
      var diff = touchStartX - e.changedTouches[0].screenX;
      if (Math.abs(diff) > 50) {
        navigate(diff > 0 ? 1 : -1);
      }
    }, { passive: true });

    // Desktop drag-to-scroll
    var track = document.getElementById('carousel-track');
    var isDown = false;
    var startX, scrollLeft, hasDragged;

    track.addEventListener('mousedown', function(e) {
      isDown = true;
      hasDragged = false;
      startX = e.pageX - track.offsetLeft;
      scrollLeft = track.scrollLeft;
    });

    track.addEventListener('mouseleave', function() { isDown = false; });
    track.addEventListener('mouseup', function() { isDown = false; });

    track.addEventListener('mousemove', function(e) {
      if (!isDown) return;
      e.preventDefault();
      var x = e.pageX - track.offsetLeft;
      var walk = (x - startX) * 1.5;
      if (Math.abs(walk) > 5) hasDragged = true;
      track.scrollLeft = scrollLeft - walk;
    });

    // Prevent click from opening lightbox after drag
    items.forEach(function(item) {
      item.addEventListener('click', function(e) {
        if (hasDragged) {
          e.stopImmediatePropagation();
          hasDragged = false;
        }
      }, true);
    });
  })();
</script>
